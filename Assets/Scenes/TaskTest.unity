MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1569542967}
  m_Enabled: 0
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 708d2baf6b11990488a760befd839b69, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MeleeState
  calculateMeleeDamage:
    formula: '(c_isWallsBetween > 0 ? 0 :

      4 - c_pawnDistance

      )'
    instruction: 
    dataAssets:
    - {fileID: 1569542970}
    - {fileID: 11400000, guid: cc0d7718186f99944bd1a02642224a2e, type: 2}
    - {fileID: 11400000, guid: cc0d7718186f99944bd1a02642224a2e, type: 2}
    names:
    - Calculated
    - Initiator
    - Target
  calculateMeleeAccuracy:
    formula: '(c_isWallsBetween > 0 ? -1 :

      c_pawnDistance > 4 ? -2 :

      c_AttackerMeleeAmount
      > 0.5 ? -3 :

      (100 - g_M) / 100

      )'
    instruction: 
    dataAssets:
    - {fileID: 1569542970}
    - {fileID: 11400000, guid: cc0d7718186f99944bd1a02642224a2e, type: 2}
    - {fileID: 11400000, guid: cc0d7718186f99944bd1a02642224a2e, type: 2}
    names:
    - Calculated
    - Initiator
    - Target
  exitCodes:
  - message: Too far
    color: {r: 1, g: 0, b: 0, a: 1}
    code: -2
  - message: Unreachable
    color: {r: 1, g: 0, b: 0, a: 1}
    code: -1
  - message: Meleed too much
    color: {r: 1, g: 0, b: 0, a: 1}
    code: -3
